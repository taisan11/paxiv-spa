{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "paxiv-spa",
  "compatibility_date": "2026-04-13",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "spa.paxiv.taisan11.dev",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
